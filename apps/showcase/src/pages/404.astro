---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Page Not Found | easy-web" lang="en">
  <div class="not-found">
    <h1>404</h1>
    <h2>Page Not Found</h2>
    <p>The page you're looking for doesn't exist or has been moved.</p>
    <a href={`${import.meta.env.BASE_URL}`} class="home-link">← Back to Home</a>
  </div>
</Base>

<style>
  .not-found {
    max-width: 600px;
    margin: 4rem auto;
    padding: 2rem 1.5rem;
    text-align: center;
  }
  .not-found h1 {
    font-size: 6rem;
    font-weight: 900;
    color: var(--ew-primary);
    margin: 0;
    line-height: 1;
  }
  .not-found h2 {
    font-size: 1.5rem;
    margin: 0.5rem 0 1rem;
  }
  .home-link {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 0.75rem 1.5rem;
    background: var(--ew-primary);
    color: var(--ew-on-primary);
    border-radius: 0.375rem;
    text-decoration: none;
    font-weight: 600;
  }
  .home-link:hover {
    opacity: 0.9;
  }
</style>
