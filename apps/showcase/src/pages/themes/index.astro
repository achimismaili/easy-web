---
import Base from '../../layouts/Base.astro';

import Hero from '@achimismaili/easy-web-content-blocks/components/Hero';
import Section from '@achimismaili/easy-web-content-blocks/components/Section';
import CardGrid from '@achimismaili/easy-web-content-blocks/components/CardGrid';
import Card from '@achimismaili/easy-web-content-blocks/components/Card';
---

<Base title="Theme Gallery - easy-web" lang="en">
  <Hero 
    title="Theme Gallery" 
    subtitle="See the same easy-web design system expressed in 4 different color palettes."
  />

  <Section title="Available Themes">
    <CardGrid>
      <Card 
        title="Ocean Theme" 
        description="Cool blues and maritime vibes." 
        href={`${import.meta.env.BASE_URL}themes/ocean/`}
        image="https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=1200&q=80" 
        imageAlt="Ocean waves"
      />
      <Card 
        title="Earth Theme" 
        description="Warm, organic greens and earthy tones." 
        href={`${import.meta.env.BASE_URL}themes/earth/`}
        image="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1200&q=80" 
        imageAlt="Forest landscape"
      />
      <Card 
        title="Sunset Theme" 
        description="Energetic and vibrant oranges and reds." 
        href={`${import.meta.env.BASE_URL}themes/sunset/`}
        image="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1200&q=80" 
        imageAlt="Sunset landscape"
      />
      <Card 
        title="Forest Theme" 
        description="A rich, deep green immersive experience." 
        href={`${import.meta.env.BASE_URL}themes/forest/`}
        image="https://images.unsplash.com/photo-1448375240586-882707db888b?w=1200&q=80" 
        imageAlt="Deep forest canopy"
      />
    </CardGrid>
  </Section>
</Base>
