---
import Base from '../../layouts/Base.astro';
import ThemeToggle from '@achimismaili/easy-web-content-blocks/components/ThemeToggle';
import LanguageSwitch from '@achimismaili/easy-web-content-blocks/components/LanguageSwitch';
import Hero from '@achimismaili/easy-web-content-blocks/components/Hero';
import Section from '@achimismaili/easy-web-content-blocks/components/Section';
import CardGrid from '@achimismaili/easy-web-content-blocks/components/CardGrid';
import Card from '@achimismaili/easy-web-content-blocks/components/Card';
import BlogPostCard from '@achimismaili/easy-web-content-blocks/components/BlogPostCard';
import Prose from '@achimismaili/easy-web-content-blocks/components/Prose';
import CtaSection from '@achimismaili/easy-web-content-blocks/components/CtaSection';
import ContactSection from '@achimismaili/easy-web-content-blocks/components/ContactSection';
import DraftBanner from '@achimismaili/easy-web-content-blocks/components/DraftBanner';
import LanguageNotice from '@achimismaili/easy-web-content-blocks/components/LanguageNotice';
import LegalLayout from '@achimismaili/easy-web-content-blocks/components/LegalLayout';
import Header from '@achimismaili/easy-web-content-blocks/components/Header';
import Footer from '@achimismaili/easy-web-content-blocks/components/Footer';
import GalleryImageGrid from '@achimismaili/easy-web-content-blocks/components/GalleryImageGrid';
import GalleryHeroSlider from '@achimismaili/easy-web-content-blocks/components/GalleryHeroSlider';
import GalleryCarousel from '@achimismaili/easy-web-content-blocks/components/GalleryCarousel';
import GalleryMasonryGrid from '@achimismaili/easy-web-content-blocks/components/GalleryMasonryGrid';
import GalleryFeatureHighlight from '@achimismaili/easy-web-content-blocks/components/GalleryFeatureHighlight';
import GalleryLightboxGrid from '@achimismaili/easy-web-content-blocks/components/GalleryLightboxGrid';
---

<Base title="Component Gallery — easy-web" lang="en">
  <div class="gallery-wrapper">
    <h1>Component Gallery</h1>
    <p>Live previews of all 16+ easy-web content blocks.</p>

    <section class="component-group">
      <h2>Navigation</h2>
      
      <div class="component-demo">
        <h3>ThemeToggle</h3>
        <p>Switches between light and dark themes using theme-core.</p>
        <div class="preview-box">
          <ThemeToggle />
        </div>
        <pre><code>import ThemeToggle from '@achimismaili/easy-web-content-blocks/components/ThemeToggle';

&lt;ThemeToggle /&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>LanguageSwitch</h3>
        <p>Links to the alternate locale version of the current page.</p>
        <div class="preview-box">
          <LanguageSwitch currentLang="en" pathname="/components/" />
        </div>
        <pre><code>import LanguageSwitch from '@achimismaili/easy-web-content-blocks/components/LanguageSwitch';

&lt;LanguageSwitch currentLang="en" pathname="/components/" /&gt;</code></pre>
      </div>
      
      <div class="component-demo">
        <h3>Header &amp; Footer</h3>
        <p>Already included in the Base layout.</p>
        <div class="preview-box">
          <div style="overflow:hidden; pointer-events:none; border: 1px solid var(--ew-border); margin-bottom: 1rem;">
            <Header siteName="easy-web" navItems={[]} currentLang="en" pathname="/components/" />
          </div>
          <div style="overflow:hidden; pointer-events:none; border: 1px solid var(--ew-border);">
            <Footer siteName="easy-web" legalLinks={[{label: "Privacy", href: "#"}, {label: "Terms", href: "#"}]} />
          </div>
        </div>
        <pre><code>import Header from '@achimismaili/easy-web-content-blocks/components/Header';
import Footer from '@achimismaili/easy-web-content-blocks/components/Footer';

&lt;Header siteName="easy-web" navItems=&amp;#123;[]&amp;#125; currentLang="en" pathname="/components/" /&gt;
&lt;Footer siteName="easy-web" legalLinks=&amp;#123;[&amp;#123;label: "Privacy", href: "#"&amp;#125;]&amp;#125; /&gt;</code></pre>
      </div>
    </section>

    <section class="component-group">
      <h2>Layout</h2>
      
      <div class="component-demo">
        <h3>Hero</h3>
        <p>Prominent hero section with optional call to action.</p>
        <div class="preview-box">
          <Hero 
            title="Showcase Your Work" 
            subtitle="Build fast, multilingual, and accessible websites." 
            ctaLabel="Click Here" 
            ctaHref="#" 
          />
        </div>
        <pre><code>import Hero from '@achimismaili/easy-web-content-blocks/components/Hero';

&lt;Hero 
  title="Showcase Your Work" 
  subtitle="Build fast, multilingual, and accessible websites." 
  ctaLabel="Click Here" 
  ctaHref="#" 
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>Section</h3>
        <p>Semantic wrapper with optional heading and constrained width.</p>
        <div class="preview-box">
          <Section title="My Section Title">
            <p>This is the content inside the section. It automatically uses the design system's spacing.</p>
          </Section>
        </div>
        <pre><code>import Section from '@achimismaili/easy-web-content-blocks/components/Section';

&lt;Section title="My Section Title"&gt;
  &lt;p&gt;This is the content inside the section. It automatically uses the design system's spacing.&lt;/p&gt;
&lt;/Section&gt;</code></pre>
      </div>
    </section>

    <section class="component-group">
      <h2>Content</h2>
      
      <div class="component-demo">
        <h3>Card &amp; CardGrid</h3>
        <p>Flexible grid layout for displaying multiple cards.</p>
        <div class="preview-box">
          <CardGrid>
            <Card title="Feature One" description="This is a great feature." href="#" />
            <Card title="Feature Two" description="This is another feature." href="#" />
          </CardGrid>
        </div>
        <pre><code>import CardGrid from '@achimismaili/easy-web-content-blocks/components/CardGrid';
import Card from '@achimismaili/easy-web-content-blocks/components/Card';

&lt;CardGrid&gt;
  &lt;Card title="Feature One" description="This is a great feature." href="#" /&gt;
  &lt;Card title="Feature Two" description="This is another feature." href="#" /&gt;
&lt;/CardGrid&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>BlogPostCard</h3>
        <p>Clickable card linking to a blog post, with date formatting.</p>
        <div class="preview-box">
          <div style="max-width: 400px;">
            <BlogPostCard 
              title="Building the component gallery" 
              description="How we built the easy-web component showcase." 
              href="#" 
                pubDate={new Date('2026-06-27')} 
              locale="en" 
            />
          </div>
        </div>
        <pre><code>import BlogPostCard from '@achimismaili/easy-web-content-blocks/components/BlogPostCard';

&lt;BlogPostCard 
  title="Building the component gallery" 
  description="How we built the easy-web component showcase." 
  href="#" 
  pubDate=&amp;#123;new Date('2026-06-27')&amp;#125; 
  locale="en" 
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>Prose</h3>
        <p>Wrapper for continuous text/markdown with typographic styling.</p>
        <div class="preview-box">
          <Prose>
            <h2>Typographic styling</h2>
            <p>Automatically applies correct spacing and styling to bare HTML tags like <code>p</code>, <code>ul</code>, and headings.</p>
          </Prose>
        </div>
        <pre><code>import Prose from '@achimismaili/easy-web-content-blocks/components/Prose';

&lt;Prose&gt;
  &lt;h2&gt;Typographic styling&lt;/h2&gt;
  &lt;p&gt;Automatically applies correct spacing and styling to bare HTML tags like &lt;code&gt;p&lt;/code&gt;, &lt;code&gt;ul&lt;/code&gt;, and headings.&lt;/p&gt;
&lt;/Prose&gt;</code></pre>
      </div>
    </section>

    <section class="component-group">
      <h2>Interactive</h2>
      
      <div class="component-demo">
        <h3>CtaSection</h3>
        <p>Call-to-action banner with heading, optional body, and button.</p>
        <div class="preview-box">
          <CtaSection 
            heading="Ready to get started?" 
            body="Join our ecosystem today." 
            buttonLabel="Sign Up" 
            buttonHref="#" 
            variant="primary" 
          />
        </div>
        <pre><code>import CtaSection from '@achimismaili/easy-web-content-blocks/components/CtaSection';

&lt;CtaSection 
  heading="Ready to get started?" 
  body="Join our ecosystem today." 
  buttonLabel="Sign Up" 
  buttonHref="#" 
  variant="primary" 
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>ContactSection</h3>
        <p>Centered mailto-only contact call to action.</p>
        <div class="preview-box">
          <ContactSection 
            heading="Need custom development?" 
            body="We are available for freelance work." 
            email="hello@example.com" 
            buttonLabel="Email Us" 
          />
        </div>
        <pre><code>import ContactSection from '@achimismaili/easy-web-content-blocks/components/ContactSection';

&lt;ContactSection 
  heading="Need custom development?" 
  body="We are available for freelance work." 
  email="hello@example.com" 
  buttonLabel="Email Us" 
/&gt;</code></pre>
      </div>
    </section>

    <section class="component-group">
      <h2>Utility</h2>
      
      <div class="component-demo">
        <h3>DraftBanner</h3>
        <p>Warning banner for draft/unfinished content.</p>
        <div class="preview-box">
          <DraftBanner message="This page is currently a draft and should not be published." />
        </div>
        <pre><code>import DraftBanner from '@achimismaili/easy-web-content-blocks/components/DraftBanner';

&lt;DraftBanner message="This page is currently a draft and should not be published." /&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>LanguageNotice</h3>
        <p>Subtle info box for language/binding disclaimers.</p>
        <div class="preview-box">
          <LanguageNotice message="Please note: The English translation is provided for convenience. Only the German original is legally binding." />
        </div>
        <pre><code>import LanguageNotice from '@achimismaili/easy-web-content-blocks/components/LanguageNotice';

&lt;LanguageNotice message="Please note: The English translation is provided for convenience. Only the German original is legally binding." /&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>LegalLayout</h3>
        <p>Narrow content wrapper for legal pages.</p>
        <div class="preview-box">
          <div style="border: 1px solid var(--ew-border); padding: 1rem; border-radius: 0.25rem;">
            <LegalLayout title="Privacy Policy" lastUpdated="June 2026">
              <p>Your privacy is important to us. This is a sample legal text to demonstrate the layout width and typography constraints applied by LegalLayout.</p>
            </LegalLayout>
          </div>
        </div>
        <pre><code>import LegalLayout from '@achimismaili/easy-web-content-blocks/components/LegalLayout';

&lt;LegalLayout title="Privacy Policy" lastUpdated="June 2026"&gt;
  &lt;p&gt;Your privacy is important to us. This is a sample legal text to demonstrate the layout width and typography constraints applied by LegalLayout.&lt;/p&gt;
&lt;/LegalLayout&gt;</code></pre>
      </div>
    <section class="component-group">
      <h2>Gallery</h2>
      
      <div class="component-demo">
        <h3>GalleryImageGrid</h3>
        <p>Simple grid of images.</p>
        <div class="preview-box">
          <GalleryImageGrid 
            title="Image Grid"
            columns={3} 
            gap="md"
            aspectRatio="square"
            items={[
              { src: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=400&q=70", alt: "Mountain landscape" },
              { src: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=400&q=70", alt: "Forest path" },
              { src: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=70", alt: "Sunlit forest" }
            ]}
          />
        </div>
        <pre><code>import GalleryImageGrid from '@achimismaili/easy-web-content-blocks/components/GalleryImageGrid';

&lt;GalleryImageGrid 
  title="Image Grid"
  columns=&amp;#123;3&amp;#125; 
  gap="md"
  aspectRatio="square"
  items=&amp;#123;[
    &amp;#123; src: "...", alt: "Mountain landscape" &amp;#125;,
    &amp;#123; src: "...", alt: "Forest path" &amp;#125;,
    &amp;#123; src: "...", alt: "Sunlit forest" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>GalleryHeroSlider</h3>
        <p>Full-width hero slider.</p>
        <div class="preview-box">
          <GalleryHeroSlider
            title="Hero Slider"
            autoplay={false}
            interval={5000}
            height="sm"
            slides={[
              { src: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&q=70", alt: "Mountains", title: "Reach New Heights", subtitle: "Discover our themed experiences", cta: "Explore", href: "#" },
              { src: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=800&q=70", alt: "Forest", title: "Into the Wild", subtitle: "Natural beauty in every pixel", cta: "Discover", href: "#" }
            ]}
          />
        </div>
        <pre><code>import GalleryHeroSlider from '@achimismaili/easy-web-content-blocks/components/GalleryHeroSlider';

&lt;GalleryHeroSlider
  title="Hero Slider"
  autoplay=&amp;#123;false&amp;#125;
  height="sm"
  slides=&amp;#123;[
    &amp;#123; src: "...", alt: "Mountains", title: "Reach New Heights", subtitle: "Discover our themed experiences", cta: "Explore", href: "#" &amp;#125;,
    &amp;#123; src: "...", alt: "Forest", title: "Into the Wild", subtitle: "Natural beauty in every pixel", cta: "Discover", href: "#" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>GalleryCarousel</h3>
        <p>Carousel of images.</p>
        <div class="preview-box">
          <GalleryCarousel
            title="Carousel"
            autoplay={false}
            interval={4000}
            showDots={true}
            showArrows={true}
            slides={[
              { src: "https://images.unsplash.com/photo-1501854140801-50d01698950b?w=600&q=70", alt: "Green hills" },
              { src: "https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=600&q=70", alt: "Lake and mountains" },
              { src: "https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=600&q=70", alt: "Ocean waves" }
            ]}
          />
        </div>
        <pre><code>import GalleryCarousel from '@achimismaili/easy-web-content-blocks/components/GalleryCarousel';

&lt;GalleryCarousel
  title="Carousel"
  autoplay=&amp;#123;false&amp;#125;
  showDots=&amp;#123;true&amp;#125;
  showArrows=&amp;#123;true&amp;#125;
  slides=&amp;#123;[
    &amp;#123; src: "...", alt: "Green hills" &amp;#125;,
    &amp;#123; src: "...", alt: "Lake and mountains" &amp;#125;,
    &amp;#123; src: "...", alt: "Ocean waves" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>GalleryMasonryGrid</h3>
        <p>Masonry grid of images.</p>
        <div class="preview-box">
          <GalleryMasonryGrid
            title="Masonry Grid"
            columns={3}
            gap="md"
            items={[
              { src: "https://images.unsplash.com/photo-1516912481808-3406841bd33c?w=400&q=70", alt: "Winter mountains" },
              { src: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=70", alt: "Forest light" },
              { src: "https://images.unsplash.com/photo-1501854140801-50d01698950b?w=400&q=70", alt: "Rolling hills" }
            ]}
          />
        </div>
        <pre><code>import GalleryMasonryGrid from '@achimismaili/easy-web-content-blocks/components/GalleryMasonryGrid';

&lt;GalleryMasonryGrid
  title="Masonry Grid"
  columns=&amp;#123;3&amp;#125;
  gap="md"
  items=&amp;#123;[
    &amp;#123; src: "...", alt: "Winter mountains" &amp;#125;,
    &amp;#123; src: "...", alt: "Forest light" &amp;#125;,
    &amp;#123; src: "...", alt: "Rolling hills" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>GalleryFeatureHighlight</h3>
        <p>Feature highlight with an image and text.</p>
        <div class="preview-box">
          <GalleryFeatureHighlight
            title="Feature Highlight"
            gap="md"
            items={[
              { src: "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=600&q=70", alt: "Mountain", title: "Design Tokens", description: "Override any visual property through CSS custom properties.", imagePosition: "left" }
            ]}
          />
        </div>
        <pre><code>import GalleryFeatureHighlight from '@achimismaili/easy-web-content-blocks/components/GalleryFeatureHighlight';

&lt;GalleryFeatureHighlight
  title="Feature Highlight"
  gap="md"
  items=&amp;#123;[
    &amp;#123; src: "...", alt: "Mountain", title: "Design Tokens", description: "Override any visual property through CSS custom properties.", imagePosition: "left" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>

      <div class="component-demo">
        <h3>GalleryLightboxGrid</h3>
        <p>Grid of images opening in a lightbox.</p>
        <div class="preview-box">
          <GalleryLightboxGrid
            title="Lightbox Grid"
            columns={3}
            gap="md"
            aspectRatio="square"
            items={[
              { src: "https://images.unsplash.com/photo-1505118380757-91f5f5632de0?w=400&q=70", alt: "Ocean", title: "Ocean", description: "Cool blue waters" },
              { src: "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=70", alt: "Forest", title: "Forest", description: "Deep green woods" },
              { src: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=400&q=70", alt: "Sunset path", title: "Sunset", description: "Golden hour" }
            ]}
          />
        </div>
        <pre><code>import GalleryLightboxGrid from '@achimismaili/easy-web-content-blocks/components/GalleryLightboxGrid';

&lt;GalleryLightboxGrid
  title="Lightbox Grid"
  columns=&amp;#123;3&amp;#125;
  gap="md"
  items=&amp;#123;[
    &amp;#123; src: "...", alt: "Ocean", title: "Ocean", description: "Cool blue waters" &amp;#125;,
    &amp;#123; src: "...", alt: "Forest", title: "Forest", description: "Deep green woods" &amp;#125;,
    &amp;#123; src: "...", alt: "Sunset path", title: "Sunset", description: "Golden hour" &amp;#125;
  ]&amp;#125;
/&gt;</code></pre>
      </div>
    </section>
  </div>
</Base>

<style>
.gallery-wrapper { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }
.component-group { margin-bottom: 3rem; }
.component-demo { margin: 1.5rem 0; border: 1px solid var(--ew-border); border-radius: 0.5rem; overflow: hidden; }
.component-demo h3 { padding: 0.75rem 1rem; background: var(--ew-surface-muted); margin: 0; font-size: 1rem; }
.component-demo p { padding: 0.5rem 1rem; margin: 0; font-size: 0.9rem; color: var(--ew-on-surface); }
.preview-box { padding: 1.5rem; border-bottom: 1px solid var(--ew-border); }
pre { margin: 0; padding: 1rem; background: var(--ew-surface-muted); font-size: 0.8rem; overflow-x: auto; }
</style>


