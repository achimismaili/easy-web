---
import { noFlashScript } from '../../../../packages/theme-core/src/helper';
import '../../../../packages/theme-core/styles/tokens.css';
import '../styles/showcase.css';

import Header from '../../../../packages/easy-web-content-blocks/src/components/Header.astro';
import Footer from '../../../../packages/easy-web-content-blocks/src/components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;

const currentLang = lang;
const pathname = Astro.url.pathname;
const isDe = currentLang === 'de';

// Normalize BASE_URL to always end with a single slash (Astro's production build may or may not preserve it).
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// Compute path relative to base.
let barePath = pathname.startsWith(base) ? pathname.slice(base.length) : pathname.replace(/^\//, '');

// Strip current locale prefix so we know the content path.
let contentPath = barePath;
if (isDe) {
  if (contentPath === 'de' || contentPath === 'de/') {
    contentPath = '';
  } else if (contentPath.startsWith('de/')) {
    contentPath = contentPath.slice(3);
  }
}

// Compute alternate locale URL (EN <-> DE).
// DE variants only exist for: home, components/, guide/. For other pages (themes, etc.),
// fall back to the DE home page so the language switch never lands on a 404.
const dePages = new Set(['', 'components/', 'guide/']);
const hasDeVariant = dePages.has(contentPath);
const alternateHref = isDe
  ? `${base}${contentPath}`
  : hasDeVariant
    ? `${base}de/${contentPath}`
    : `${base}de/`;

// Compute brand link (home page of current locale)
const brandHref = isDe ? `${base}de/` : base;

// Nav: only localize pages that actually have DE variants (components, guide).
// Themes + Docs are EN-only, so always link to EN URL.
const navItems = [
  { label: isDe ? 'Startseite' : 'Home', href: brandHref },
  { label: 'Themes', href: `${base}themes/` },
  { label: isDe ? 'Komponenten' : 'Components', href: `${base}${isDe ? 'de/' : ''}components/` },
  { label: 'Guide', href: `${base}${isDe ? 'de/' : ''}guide/` },
  { label: 'Docs', href: `${base}docs/` },
];

// Imprint/Privacy pages do not exist yet in the showcase; omit them from the footer.
const legalLinks: Array<{ label: string; href: string }> = [];
---
<!doctype html>
<html lang={lang}>
  <head>
    <script is:inline set:html={noFlashScript}></script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <Header
      siteName="easy-web"
      navItems={navItems}
      currentLang={currentLang}
      pathname={pathname}
      brandHref={brandHref}
      alternateHref={alternateHref}
    />
    <main>
      <slot />
    </main>
    <Footer siteName="easy-web" legalLinks={legalLinks} />
  </body>
</html>
