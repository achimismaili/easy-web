{
  "name": "@achimismaili/easy-web-cms-adapters",
  "version": "0.2.0",
  "packageManager": "pnpm@10.34.4",
  "type": "module",
  "private": false,
  "description": "Decap CMS integration for the easy-web ecosystem — AdminPage component, frontmatter types, and config scaffold.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*.astro",
    "./src/components/*.astro": "./src/components/*.astro"
  },
  "files": ["dist", "src/components", "README.md"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "peerDependencies": {
    "astro": ">=6.0.0 <8.0.0"
  },
  "devDependencies": {
    "astro": "^6.4.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achimismaili/easy-web.git",
    "directory": "packages/easy-web-cms-adapters"
  }
}
