{
  "name": "@achimismaili/easy-web-seo",
  "version": "1.0.0",
  "type": "module",
  "description": "Shared SEO primitives for @achimismaili/easy-web-* consumer instances — Astro integration wrapping @astrojs/sitemap with i18n hreflang, dynamic robots.txt route with noIndex mode, and <SeoHead> component (canonical, OpenGraph, Twitter Cards, hreflang, theme-color, manifest).",
  "keywords": [
    "astro-integration",
    "astro-component",
    "seo",
    "sitemap",
    "robots.txt",
    "opengraph",
    "hreflang",
    "canonical"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*.astro"
  },
  "files": [
    "dist",
    "src/components",
    "src/routes",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": ">=6.0.0 <8.0.0",
    "@achimismaili/easy-web-i18n": ">=1.0.0"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3"
  },
  "devDependencies": {
    "astro": "^6.4.0",
    "@achimismaili/easy-web-i18n": "workspace:*",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achimismaili/easy-web.git",
    "directory": "packages/seo"
  },
  "license": "MIT"
}
