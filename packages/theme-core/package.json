{
  "name": "@achimismaili/easy-web-theme-core",
  "version": "0.5.0",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./styles/tokens.css",
    "./fonts.css": "./styles/fonts.css"
  },
  "files": ["dist", "styles", "README.md"],
  "sideEffects": ["*.css"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achimismaili/easy-web.git",
    "directory": "packages/theme-core"
  },
  "license": "UNLICENSED"
}
