{
  "name": "@achimismaili/easy-web-content-blocks",
  "version": "0.6.1",
  "packageManager": "pnpm@9.15.4",
  "type": "module",
  "description": "Reusable Astro content-block components for the easy-web ecosystem.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*.astro",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "files": [
    "dist",
    "src/components",
    "src/schemas",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@achimismaili/easy-web-theme-core": "workspace:*",
    "astro": ">=6.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@achimismaili/easy-web-theme-core": "workspace:*",
    "typescript": "^5.5.0",
    "astro": "^6.4.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achimismaili/easy-web.git",
    "directory": "packages/easy-web-content-blocks"
  },
  "license": "UNLICENSED"
}
