{
  "name": "@achimismaili/easy-web-content-blocks",
  "version": "1.1.0",
  "packageManager": "pnpm@10.34.4",
  "type": "module",
  "description": "Reusable Astro content-block components for the easy-web ecosystem.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*.astro",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "files": [
    "dist",
    "src/components",
    "src/schemas",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@achimismaili/easy-web-i18n": ">=1.0.0",
    "@achimismaili/easy-web-theme-core": ">=1.0.0",
    "astro": ">=6.0.0 <8.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@achimismaili/easy-web-theme-core": "workspace:*",
    "astro": "^6.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/achimismaili/easy-web.git",
    "directory": "packages/easy-web-content-blocks"
  },
  "license": "MIT"
}
